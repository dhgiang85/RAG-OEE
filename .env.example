# RAG v3 environment variables. Copy to .env and fill in.

# ─── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_dev_password
POSTGRES_DB=rag
POSTGRES_PORT=5432
DATABASE_URL=postgres://rag:rag_dev_password@postgres:5432/rag

# ─── MinIO ────────────────────────────────────────────────────────────
MINIO_ROOT_USER=rag_minio
MINIO_ROOT_PASSWORD=rag_dev_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=rag_minio
MINIO_SECRET_KEY=rag_dev_minio_password
MINIO_BUCKET=documents

# ─── Filesystem pipeline ──────────────────────────────────────────────
# All five folders live under DATA_ROOT. The parser writes to need-checked/;
# the embedder watches accepted/ and moves files to embedded/ on success.
DATA_ROOT=/data
PARSED_NEED_CHECKED=/data/parsed/need-checked
PARSED_ACCEPTED=/data/parsed/accepted
PARSED_RE_EMBED=/data/parsed/re-embed
PARSED_EMBEDDED=/data/parsed/embedded
PARSED_REJECTED=/data/parsed/rejected

# ─── Ollama (host) ────────────────────────────────────────────────────
# Same Ollama instance is used for embeddings AND for the LLM fallback.
OLLAMA_BASE_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=16
LLM_FALLBACK_MODEL=qwen2.5:14b-instruct

# ─── Parser catalog ───────────────────────────────────────────────────
# Comma-separated list of engines enabled at runtime. The first one is default.
PARSER_ENGINES=pymupdf,pymupdf+ocr,docling,llamaparse
PARSER_DEFAULT_ENGINE=pymupdf
PYMUPDF_OCR_ENGINE=rapidocr        # rapidocr | tesseract | auto
PYMUPDF_FORCE_OCR=false
PYMUPDF_OCR_LANGUAGE=eng+vie
PYMUPDF_OCR_DPI=200
LLAMAPARSE_API_KEY=

# ─── LLM (Phase 3 spine: Ollama only) ─────────────────────────────────
LLM_PRIMARY_PROVIDER=ollama
LLM_PRIMARY_MODEL=gemma4:31b-cloud
LLM_FALLBACK_PROVIDER=
LLM_TIMEOUT_SECONDS=120
MAX_OUTPUT_TOKENS=1024
MAX_QUERY_CHARS=4000
HISTORY_LIMIT=10
ENABLE_QUERY_REWRITING=true

# ─── Query Decomposition (Multi-Vector Retrieval) ─────────────────────
# When ENABLE_QUERY_DECOMPOSITION is true, compound queries are split into
# sub-queries via LLM, each embedded separately for multi-vector search.
# For best performance and lowest latency, use a fast, lightweight model
# (e.g. qwen2.5:7b-instruct or qwen2.5:14b-instruct). If left blank,
# LLM_PRIMARY_MODEL is used.
ENABLE_QUERY_DECOMPOSITION=true
DECOMPOSITION_MODEL=qwen2:1.5b-instruct
MAX_SUB_QUERIES=3
# Skip decompose LLM call when query has < N words (default 8).
DECOMPOSE_MIN_WORDS=8
# Model riêng cho rewrite (condense follow-up). Empty → fallback
# DECOMPOSITION_MODEL → LLM_PRIMARY_MODEL.
REWRITE_MODEL=qwen2:1.5b-instruct

# ─── Performance tuning ───────────────────────────────────────────────
PG_MAX_CONNS=20
PG_MIN_CONNS=4
HTTP_MAX_IDLE_PER_HOST=20
EMBEDDING_VALIDATE=true
# Cap entity count in IsGlobalOEE stats block (rank by incident count).
GLOBAL_OEE_TOP_N=15

# (Phase 4 — uncomment to switch primary to Claude)
# LLM_PRIMARY_PROVIDER=claude
# LLM_PRIMARY_MODEL=claude-sonnet-4-7
# ANTHROPIC_API_KEY=sk-ant-
# ANTHROPIC_ENABLE_PROMPT_CACHE=true

# ─── Retriever / Chat / Ingestion ports ───────────────────────────────
RETRIEVER_URL=http://retriever:8003
RETRIEVER_PORT=8003
RETRIEVAL_TOP_K=50
CHAT_PORT=8004
INGEST_PORT=8001
MAX_UPLOAD_BYTES=104857600

# ─── Auth (Phase 4) ───────────────────────────────────────────────────
# Dev fallback: empty JWT_SECRET lets the gateway autogenerate per-process
# AND enables X-Dev-Tenant-Id / X-Dev-User-Id fallback headers. Set a 32+
# char random string in prod.
JWT_SECRET=af46a309f5cd5cf689ac59fe230c6941369c99bc4a003c841484ab967ea151b8
JWT_ACCESS_TTL_SECONDS=86400
JWT_REFRESH_TTL_SECONDS=2592000

# ─── Gateway downstream URLs (Phase 4) ────────────────────────────────
INGESTION_URL=http://ingestion:8001
PARSER_URL=http://parser-catalog:8002
EMBEDDER_URL=http://embedder:8005
CHAT_URL=http://chat:8004

# ─── Rate limiting (Phase 4) ──────────────────────────────────────────
RATE_LIMIT_RPM_USER=30
RATE_LIMIT_RPM_IP=100
RATE_LIMIT_TOKENS_PER_DAY=100000
HEALTHZ_CACHE_SECONDS=5

# ─── Observability ────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
GATEWAY_PORT=8000
FRONTEND_PORT=3000

# ─── Job queue (own table; replaces pg-boss) ──────────────────────────
JOBS_DEFAULT_MAX_ATTEMPTS=3
JOBS_PARSE_LOCK_SECONDS=300       # parser-catalog claim lock
JOBS_EMBED_LOCK_SECONDS=120       # embed-retry claim lock
JOBS_POLL_FALLBACK_SECONDS=60     # safety poll if NOTIFY dropped
